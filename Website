<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TETSUNARU — Ege Demir Ünal</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&family=Lora:ital,wght@0,400;0,500;1,400&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Noto+Serif+JP:wght@200;300&display=swap" rel="stylesheet">
<style>
:root {
  --bg:      #0a0808;
  --bg2:     #111010;
  --bg3:     #181414;
  --text:    #e8dfd6;
  --text2:   #b8aca3;
  --muted:   #706560;
  --red:     #d44040;
  --red2:    #e05555;
  --red-dim: rgba(212,64,64,0.14);
  --border:  rgba(212,64,64,0.16);
  --sw:      270px;
  --T: 'Playfair Display', Georgia, serif;
  --B: 'Lora', Georgia, serif;
  --M: 'Space Mono', monospace;
  --J: 'Noto Serif JP', serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--B);font-size:16px;line-height:1.8;overflow-x:hidden}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--red)}
a{color:inherit;text-decoration:none}img{display:block;max-width:100%}
button{cursor:pointer;background:none;border:none;font-family:inherit;color:inherit}

/* ══ SIDEBAR ══════════════════════════════ */
.sb{
  position:fixed;top:0;left:0;width:var(--sw);height:100vh;
  background:var(--bg2);border-right:1px solid var(--border);
  display:flex;flex-direction:column;overflow-y:auto;z-index:100;
}
.sb-brand{padding:36px 28px 28px;border-bottom:1px solid var(--border)}
.sb-label{
  font-family:var(--M);font-size:0.78rem;letter-spacing:.22em;
  text-transform:uppercase;color:var(--red);margin-bottom:10px;
  font-weight:700;
}
.sb-name{font-family:var(--T);font-size:1.55rem;font-weight:600;line-height:1.15;color:var(--text)}
.sb-handle{font-family:var(--M);font-size:0.82rem;color:var(--muted);margin-top:6px;letter-spacing:.12em}
.sb-jp{font-family:var(--J);font-size:0.72rem;font-weight:200;color:var(--muted);margin-top:7px;letter-spacing:.22em}

.sb-nav{padding:22px 0;flex:1}
.sb-grp{margin-bottom:20px}
.sb-grp-lbl{
  font-family:var(--M);font-size:0.72rem;letter-spacing:.26em;
  text-transform:uppercase;color:var(--red);padding:0 28px 10px;
  font-weight:700;
}
.sb-btn{
  display:block;width:100%;text-align:left;padding:9px 28px;
  font-family:var(--B);font-size:1.05rem;color:var(--muted);
  border-left:2px solid transparent;transition:all .18s;
}
.sb-btn:hover{color:var(--text);background:var(--red-dim)}
.sb-btn.on{color:var(--text);border-left-color:var(--red);background:rgba(212,64,64,.07)}

.sb-archive-wrap{padding:0 28px 20px}
.sb-archive-btn{
  width:100%;padding:10px 18px;
  display:flex;align-items:center;justify-content:space-between;
  border:1px solid var(--border);font-family:var(--M);
  font-size:0.78rem;letter-spacing:.14em;text-transform:uppercase;
  color:var(--muted);transition:all .18s;
}
.sb-archive-btn:hover{color:var(--text);border-color:rgba(212,64,64,.5)}
.sb-archive-btn .arr{font-family:var(--T);font-size:1rem;color:var(--red)}

.sb-foot{padding:20px 28px;border-top:1px solid var(--border)}
.sb-foot p{font-family:var(--M);font-size:0.78rem;color:var(--muted);line-height:1.9;margin-bottom:14px}
.sb-links{display:flex;flex-direction:column;gap:8px}
.sb-links a{font-family:var(--M);font-size:0.78rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);transition:color .18s}
.sb-links a:hover{color:var(--red)}

/* ══ MAIN ══════════════════════════════ */
.main{margin-left:var(--sw);min-height:100vh;width:calc(100% - var(--sw))}
.page{display:none}
.page.active{display:block;animation:fi .35s ease}
@keyframes fi{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}

/* ══ PAGE HEADER ══════════════════════════ */
.ph{padding:68px 64px 48px;border-bottom:1px solid var(--border);position:relative;overflow:hidden}
.ph-wm{position:absolute;right:44px;top:50%;transform:translateY(-50%);font-family:var(--J);font-size:108px;font-weight:200;color:rgba(212,64,64,.045);letter-spacing:.3em;pointer-events:none;white-space:nowrap;line-height:1}
.ph-eyebrow{font-family:var(--M);font-size:0.88rem;letter-spacing:.22em;text-transform:uppercase;color:var(--red);margin-bottom:14px}
.ph-title{font-family:var(--T);font-size:clamp(2.6rem,5.5vw,4.5rem);font-weight:900;line-height:.95;letter-spacing:-.01em;color:var(--text)}
.ph-sub{margin-top:14px;font-family:var(--B);font-size:1.05rem;font-style:italic;color:var(--text2);max-width:500px}

/* ══ HOME — full centered ══════════════════ */
#pg-home.active{
  display:flex;align-items:center;justify-content:center;
  min-height:100vh;flex-direction:column;
  position:relative;overflow:hidden;
}
.home-glow{position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 40%,rgba(212,64,64,.06) 0%,transparent 70%);pointer-events:none}

.home-hero{
  display:flex;flex-direction:column;align-items:center;
  text-align:center;width:100%;max-width:900px;
  padding:80px 64px 56px;position:relative;z-index:2;
}
.h-eyebrow{font-family:var(--M);font-size:0.65rem;letter-spacing:.35em;text-transform:uppercase;color:var(--red);margin-bottom:24px}
/* SINGLE LINE NAME */
.h-name{
  font-family:var(--T);
  font-size:clamp(2.8rem,7vw,6.5rem);
  font-weight:900;line-height:1;letter-spacing:-.02em;
  white-space:nowrap;color:var(--text);
}
.h-name .d1{color:inherit}
.h-name .d2{color:inherit;margin:0 0.15em}
.h-name .d3{color:inherit;font-style:normal}
.h-jp{font-family:var(--J);font-size:1.05rem;font-weight:200;color:var(--text2);letter-spacing:.4em;margin-top:18px}
.h-rule{width:52px;height:1px;background:var(--red);opacity:.45;margin:30px auto}
.h-bio{font-family:var(--B);font-size:1.08rem;color:var(--text2);line-height:1.9;max-width:460px}
.h-bio strong{color:var(--text);font-weight:500}
.h-btns{display:flex;flex-wrap:wrap;gap:10px;margin-top:34px;justify-content:center}
.hbtn{font-family:var(--M);font-size:0.65rem;letter-spacing:.2em;text-transform:uppercase;padding:12px 28px;transition:all .18s}
.hbtn-p{background:var(--red);color:var(--text)}
.hbtn-p:hover{background:var(--red2)}
.hbtn-g{border:1px solid var(--border);color:var(--muted)}
.hbtn-g:hover{border-color:rgba(212,64,64,.55);color:var(--text)}

/* HOME SERVICES */
.home-services{width:100%;padding:56px 64px;border-top:1px solid var(--border)}
.hs-title{font-family:var(--T);font-size:2.2rem;font-weight:700;color:var(--text);text-align:center;margin-bottom:8px}
.hs-sub{font-family:var(--B);font-size:1rem;color:var(--text2);text-align:center;font-style:italic;margin-bottom:44px}
.hs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.hs-card{
  background:var(--bg2);padding:28px 24px;
  border:1px solid var(--border);
  transition:border-color .2s,background .2s;
}
.hs-card:hover{background:var(--bg3);border-color:rgba(212,64,64,.4)}
.hs-icon{
  width:48px;height:48px;background:var(--red);
  display:flex;align-items:center;justify-content:center;
  margin-bottom:18px;font-size:1.3rem;
}
.hs-card-title{font-family:var(--T);font-size:1.1rem;font-weight:700;color:var(--text);margin-bottom:10px}
.hs-card-desc{font-family:var(--B);font-size:0.9rem;color:var(--text2);line-height:1.7}

/* HOME CONTACT */
.home-contact{
  width:100%;padding:60px 64px;
  border-top:1px solid var(--border);
  display:flex;flex-direction:column;align-items:center;
  text-align:center;
}
.hc-title{font-family:var(--T);font-size:2.6rem;font-weight:900;color:var(--red);margin-bottom:14px}
.hc-sub{font-family:var(--B);font-size:1.05rem;color:var(--text2);max-width:520px;line-height:1.8;margin-bottom:28px}
.hc-btn{
  font-family:var(--M);font-size:0.72rem;letter-spacing:.2em;
  text-transform:uppercase;padding:14px 40px;
  background:var(--red);color:var(--text);transition:background .18s;
}
.hc-btn:hover{background:var(--red2)}

/* ══ ARCHIVE ══════════════════════════════ */
.archive-wrap{padding:56px 64px 80px}
.archive-intro{font-family:var(--B);font-size:1.05rem;color:var(--text2);margin-bottom:44px;font-style:italic;max-width:520px}
.arc-list{display:flex;flex-direction:column;gap:2px}
.arc-card{
  background:var(--bg2);display:flex;align-items:center;
  padding:28px 36px;gap:32px;
  border-left:3px solid transparent;transition:all .2s;cursor:pointer;
}
.arc-card:hover{background:var(--bg3);border-left-color:var(--red)}
.arc-y{font-family:var(--T);font-size:3.8rem;font-weight:900;color:var(--red);line-height:1;min-width:110px;opacity:.35;transition:opacity .2s}
.arc-card:hover .arc-y{opacity:.7}
.arc-info{flex:1}
.arc-cnt{font-family:var(--M);font-size:0.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--red);margin-bottom:8px}
.arc-cats{display:flex;gap:8px;flex-wrap:wrap}
.arc-cat{font-family:var(--M);font-size:0.58rem;padding:3px 10px;border:1px solid var(--border);color:var(--muted);letter-spacing:.1em}
.arc-btn{font-family:var(--M);font-size:0.6rem;letter-spacing:.2em;text-transform:uppercase;padding:10px 22px;border:1px solid var(--border);color:var(--muted);transition:all .18s}
.arc-card:hover .arc-btn{background:var(--red);border-color:var(--red);color:var(--text)}

/* ══ PORTFOLIO ══════════════════════════════ */
.port-ctrl{padding:24px 64px;border-bottom:1px solid var(--border);display:flex;flex-direction:column;gap:14px}
.year-row{display:flex;gap:0}
.yr-btn{font-family:var(--T);font-size:1.35rem;font-weight:500;padding:8px 26px 8px 0;color:var(--muted);border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .18s}
.yr-btn:hover{color:var(--text2)}
.yr-btn.on{color:var(--text);border-bottom-color:var(--red)}
.cat-row{display:flex;gap:6px;flex-wrap:wrap}
.cat-btn{font-family:var(--M);font-size:0.6rem;letter-spacing:.18em;text-transform:uppercase;padding:6px 14px;border:1px solid var(--border);color:var(--muted);transition:all .18s}
.cat-btn:hover{color:var(--text2)}
.cat-btn.on{background:var(--red-dim);border-color:rgba(212,64,64,.45);color:var(--text)}

.port-list{padding:40px 64px 80px;display:flex;flex-direction:column;gap:3px}
.port-card{display:grid;grid-template-columns:320px 1fr;background:var(--bg2);overflow:hidden;transition:background .2s}
.port-card:hover{background:var(--bg3)}
.port-img-wrap{position:relative;overflow:hidden;cursor:pointer;aspect-ratio:3/4;max-height:400px}
.port-img-wrap img{width:100%;height:100%;object-fit:cover;transition:transform .55s ease,filter .3s;filter:brightness(.75) saturate(.85)}
.port-card:hover .port-img-wrap img{transform:scale(1.03);filter:brightness(.88) saturate(1)}
.port-img-open{position:absolute;bottom:12px;right:12px;font-family:var(--M);font-size:0.55rem;letter-spacing:.18em;text-transform:uppercase;padding:6px 12px;background:rgba(10,8,8,.8);color:var(--text2);border:1px solid var(--border);opacity:0;transition:opacity .25s}
.port-card:hover .port-img-open{opacity:1}
.port-yr-badge{position:absolute;top:12px;left:12px;font-family:var(--M);font-size:0.58rem;background:rgba(10,8,8,.8);color:var(--muted);padding:3px 9px;letter-spacing:.1em}
.port-info{padding:36px 42px;display:flex;flex-direction:column;justify-content:center}
.pi-cat{font-family:var(--M);font-size:0.6rem;letter-spacing:.25em;text-transform:uppercase;color:var(--red);margin-bottom:10px}
.pi-title{font-family:var(--T);font-size:1.9rem;font-weight:700;line-height:1.1;color:var(--text);margin-bottom:14px}
.pi-desc{font-family:var(--B);font-size:0.95rem;color:var(--text2);line-height:1.85;margin-bottom:22px}
.pi-tags{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:26px}
.pi-tag{font-family:var(--M);font-size:0.58rem;padding:4px 12px;border:1px solid var(--border);color:var(--muted);letter-spacing:.08em}
.pi-link{display:inline-flex;align-items:center;gap:8px;font-family:var(--M);font-size:0.6rem;letter-spacing:.15em;text-transform:uppercase;color:var(--red);border-bottom:1px solid rgba(212,64,64,.3);padding-bottom:2px;width:fit-content;transition:color .18s}
.pi-link:hover{color:var(--red2)}

/* ══ SKETCHES — grid ══════════════════════ */
.sk-ctrl{padding:24px 64px;border-bottom:1px solid var(--border)}
.sk-grid{
  padding:20px 20px 80px;
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:4px;
}
.sk-item{cursor:pointer;overflow:hidden;position:relative;background:var(--bg3)}
.sk-item::after{content:'';display:block;padding-top:100%}
.sk-item img{
  position:absolute;inset:0;width:100%;height:100%;
  object-fit:cover;
  transition:filter .3s,transform .4s;filter:saturate(.8) brightness(.85);
}
.sk-item:hover img{filter:saturate(1.05) brightness(1);transform:scale(1.04)}
.sk-lbl{
  position:absolute;bottom:0;left:0;right:0;
  padding:28px 12px 9px;
  background:linear-gradient(to top,rgba(10,8,8,.88),transparent);
  font-family:var(--M);font-size:0.6rem;color:var(--text2);
  letter-spacing:.08em;opacity:0;transition:opacity .25s;
}
.sk-item:hover .sk-lbl{opacity:1}

/* ══ WORLDBUILDING — card grid ══════════════════ */
.wb-ctrl{padding:24px 64px;border-bottom:1px solid var(--border);display:flex;gap:8px;flex-wrap:wrap}
.wb-pill{font-family:var(--M);font-size:0.6rem;letter-spacing:.18em;text-transform:uppercase;padding:7px 18px;border:1px solid var(--border);color:var(--muted);border-radius:999px;transition:all .18s}
.wb-pill:hover{color:var(--text);border-color:rgba(212,64,64,.4)}
.wb-pill.on{background:var(--red);color:var(--text);border-color:var(--red)}

.wb-grid{padding:40px 64px 80px;display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px}
.wb-card{background:var(--bg2);overflow:hidden;transition:background .2s;cursor:pointer;display:flex;flex-direction:column}
.wb-card:hover{background:var(--bg3)}
.wb-card-img{position:relative;height:200px;overflow:hidden;background:var(--bg3)}
.wb-card-img img{width:100%;height:100%;object-fit:cover;filter:brightness(.7) saturate(.8);transition:transform .5s,filter .3s}
.wb-card:hover .wb-card-img img{transform:scale(1.04);filter:brightness(.85) saturate(1)}
.wb-card-date{position:absolute;top:12px;right:12px;font-family:var(--M);font-size:0.58rem;background:rgba(10,8,8,.82);color:var(--text2);padding:4px 10px;letter-spacing:.08em}
.wb-card-body{padding:22px 24px;flex:1;display:flex;flex-direction:column}
.wb-card-cat{display:inline-block;font-family:var(--M);font-size:0.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--red);padding:3px 10px;border:1px solid rgba(212,64,64,.25);margin-bottom:12px;width:fit-content}
.wb-card-title{font-family:var(--T);font-size:1.1rem;font-weight:700;font-style:italic;line-height:1.35;color:var(--text);margin-bottom:10px}
.wb-card-excerpt{font-family:var(--B);font-size:0.88rem;color:var(--text2);line-height:1.75;flex:1}
.wb-card-chips{display:flex;gap:5px;flex-wrap:wrap;margin-top:14px}
.wb-chip{font-family:var(--M);font-size:0.56rem;padding:2px 8px;color:var(--muted);background:rgba(255,255,255,.025);letter-spacing:.06em}
.wb-card-footer{padding:14px 24px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.wb-card-more{font-family:var(--M);font-size:0.6rem;letter-spacing:.16em;text-transform:uppercase;color:var(--red);display:flex;align-items:center;gap:6px;transition:color .18s}
.wb-card:hover .wb-card-more{color:var(--red2)}

/* ══ GAMES ══════════════════════════════ */
.games-wrap{padding:52px 64px 80px}
.game-card{margin-bottom:4px;background:var(--bg2);overflow:hidden}
.game-cover{position:relative;height:272px;overflow:hidden}
.game-cover img{width:100%;height:100%;object-fit:cover;filter:brightness(.28) saturate(.5);transition:filter .45s}
.game-card:hover .game-cover img{filter:brightness(.38) saturate(.7)}
.game-cover-over{position:absolute;inset:0;padding:38px 48px;display:flex;flex-direction:column;justify-content:flex-end}
.gco-st{font-family:var(--M);font-size:0.6rem;letter-spacing:.28em;text-transform:uppercase;color:var(--red);margin-bottom:9px}
.gco-t{font-family:var(--T);font-size:clamp(2rem,4vw,3.2rem);font-weight:900;line-height:.95;letter-spacing:-.01em}
.game-body{padding:38px 48px;display:grid;grid-template-columns:1fr 210px;gap:42px}
.gb-desc{font-family:var(--B);font-size:1rem;color:var(--text2);line-height:1.9;margin-bottom:20px}
.gb-tags{display:flex;flex-wrap:wrap;gap:7px}
.gb-tag{font-family:var(--M);font-size:0.6rem;padding:5px 14px;border:1px solid var(--border);color:var(--text2);letter-spacing:.1em}
.g-aside{border-left:1px solid var(--border);padding-left:28px}
.ga-lbl{font-family:var(--M);font-size:0.58rem;letter-spacing:.28em;text-transform:uppercase;color:var(--red);margin-bottom:10px}
.ga-feat{font-family:var(--B);font-size:0.88rem;color:var(--text2);padding:6px 0;border-bottom:1px solid rgba(212,64,64,.07)}
.ga-feat::before{content:'→ ';color:var(--red);font-family:var(--M)}
.ga-tgt{margin-top:20px}
.ga-tgt strong{display:block;font-family:var(--M);font-size:0.55rem;letter-spacing:.25em;text-transform:uppercase;color:var(--red);margin-bottom:5px}
.ga-tgt span{font-family:var(--B);font-size:0.9rem;color:var(--text2)}

/* ══ ABOUT ══════════════════════════════ */
.about-wrap{padding:52px 64px 80px}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:3px}
.ab-full{grid-column:1/-1}
.ab-block{background:var(--bg2);padding:34px}
.ab-t{font-family:var(--T);font-size:1.45rem;font-weight:700;color:var(--red);margin-bottom:16px;line-height:1}
.ab-p{font-family:var(--B);font-size:1rem;color:var(--text2);line-height:1.9}
.ab-p+.ab-p{margin-top:11px}
.ab-p strong{color:var(--text);font-weight:500}
.ab-tools{display:flex;flex-wrap:wrap;gap:7px;margin-top:15px}
.ab-tool{font-family:var(--M);font-size:0.62rem;padding:5px 12px;border:1px solid var(--border);color:var(--text2);letter-spacing:.1em}
.tl{margin-top:4px}
.tl-row{display:flex;gap:16px;padding:10px 0;border-bottom:1px solid rgba(212,64,64,.07)}
.tl-yr{font-family:var(--T);font-size:1rem;font-weight:600;color:var(--red);min-width:44px}
.tl-t{font-family:var(--B);font-size:0.92rem;color:var(--text2);line-height:1.65;padding-top:1px}

/* ══ GALLERY MODAL ══════════════════════ */
.gm-overlay{
  display:none;position:fixed;inset:0;z-index:500;
  background:rgba(6,4,4,.78);
  backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  align-items:center;justify-content:center;padding:40px;
}
.gm-overlay.open{display:flex;animation:fi .25s ease}
.gm-panel{
  display:grid;grid-template-columns:1fr 380px;
  width:100%;max-width:1100px;max-height:88vh;
  background:var(--bg2);overflow:hidden;border:1px solid var(--border);
}
.gm-img-side{position:relative;overflow:hidden;background:var(--bg3);min-height:500px}
.gm-img-side img{width:100%;height:100%;object-fit:contain;padding:24px}
.gm-nav{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);display:flex;gap:10px}
.gm-nav-btn{font-family:var(--M);font-size:0.6rem;letter-spacing:.15em;padding:7px 18px;border:1px solid var(--border);color:var(--text2);transition:all .18s;background:rgba(10,8,8,.75)}
.gm-nav-btn:hover{border-color:var(--red);color:var(--text)}
.gm-info{padding:40px 38px;display:flex;flex-direction:column;border-left:1px solid var(--border);overflow-y:auto}
