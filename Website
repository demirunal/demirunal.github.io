  const years = [...new Set(all.map(d => d.year))].sort((a, b) => b - a);
  document.getElementById('archiveContent').innerHTML = `
    <p class="archive-intro">Select a year to browse all work from that period.</p>
    <div class="arc-list">
      ${years.map(y => {
        const cnt = all.filter(d => d.year === y).length;
        const cats = [...new Set([
          ...portData.filter(d => d.year === y).map(d => d.cat),
          skData.filter(d => d.year === y).length ? 'Sketch' : null,
          wbData.filter(d => d.year === y).length ? 'Worldbuilding' : null
        ].filter(Boolean))];
        return `<div class="arc-card" onclick="goYear(${y})">
          <div class="arc-y">${y}</div>
          <div class="arc-info">
            <div class="arc-cnt">${cnt} pieces</div>
            <div class="arc-cats">${cats.map(c => `<span class="arc-cat">${c}</span>`).join('')}</div>
          </div>
          <button class="arc-btn">Browse ${y} →</button>
        </div>`;
      }).join('')}
    </div>`;
}

function goYear(y) {
  pY = String(y); pC = 'all';
  go('portfolio');
  renderPort();
}

/* ══ PORTFOLIO ══════════════════════════ */
let pY = 'all', pC = 'all';
function renderPort() {
  const yrs = ['all', ...new Set(portData.map(p => p.year).sort((a, b) => b - a))];
  const cats = ['all', ...new Set(portData.map(p => p.cat))];
  document.getElementById('portYears').innerHTML = yrs.map(y =>
    `<button class="yr-btn ${pY == y ? 'on' : ''}" onclick="pSetY('${y}')">${y === 'all' ? 'All' : y}</button>`).join('');
  document.getElementById('portCats').innerHTML = cats.map(c =>
    `<button class="cat-btn ${pC == c ? 'on' : ''}" onclick="pSetC('${c}')">${c === 'all' ? 'All' : c}</button>`).join('');
  const f = portData.filter(p => (pY === 'all' || p.year == pY) && (pC === 'all' || p.cat === pC));
  // Store filtered for modal
  currentPortFiltered = f;
  document.getElementById('portList').innerHTML = f.map((p, i) => `
    <div class="port-card">
      <div class="port-img-wrap" onclick="openGM('port',${i})">
        <img src="${p.img}" alt="${p.title}" loading="lazy">
        <div class="port-yr-badge">${p.year}</div>
        <div class="port-img-open">View Full →</div>
      </div>
      <div class="port-info">
        <div class="pi-cat">${p.cat}</div>
        <div class="pi-title">${p.title}</div>
        <p class="pi-desc">${p.desc}</p>
        <div class="pi-tags">${p.tags.map(t => `<span class="pi-tag">${t}</span>`).join('')}</div>
        <a class="pi-link" href="${p.link}" target="_blank">View on ArtStation ↗</a>
      </div>
    </div>`).join('');
}
function pSetY(y) { pY = y; renderPort(); }
function pSetC(c) { pC = c; renderPort(); }
let currentPortFiltered = portData;

/* ══ SKETCHES ═══════════════════════════ */
let sY = 'all';
function renderSk() {
  const yrs = ['all', ...new Set(skData.map(s => s.year).sort((a, b) => b - a))];
  document.getElementById('skYears').innerHTML = yrs.map(y =>
    `<button class="yr-btn ${sY == y ? 'on' : ''}" onclick="sSetY('${y}')">${y === 'all' ? 'All' : y}</button>`).join('');
  const f = skData.filter(s => sY === 'all' || s.year == sY);
  currentSkFiltered = f;
  document.getElementById('skGrid').innerHTML = f.map((s, i) => {
    if (s.img) {
      return `<div class="sk-item" onclick="openGM('sk',${i})">
        <img src="${s.img}" alt="${s.lbl}" loading="lazy">
        <div class="sk-lbl">${s.lbl}</div>
      </div>`;
    }
    // Placeholder tile
    return `<div class="sk-item" onclick="openGM('sk',${i})" style="background:${s.col}">
      <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:16px">
        <div style="font-family:var(--M);font-size:0.55rem;color:var(--muted);letter-spacing:.15em;text-transform:uppercase;text-align:center;line-height:1.6">${s.lbl}</div>
        <div style="margin-top:12px;font-size:2rem;opacity:.1">✏</div>
      </div>
      <div class="sk-lbl">${s.lbl}</div>
    </div>`;
  }).join('');
}
function sSetY(y) { sY = y; renderSk(); }
let currentSkFiltered = skData;

/* ══ WORLDBUILDING ══════════════════════ */
let wbCat = 'all';
const wbCats = ['all', 'Characters', 'Cities', 'Lore', 'Events'];

function renderWBPills() {
  document.getElementById('wbPills').innerHTML = wbCats.map(c =>
    `<button class="wb-pill ${wbCat === c ? 'on' : ''}" onclick="setWbCat('${c}')">${c === 'all' ? 'All' : c}</button>`
  ).join('');
}

function setWbCat(c) { wbCat = c; renderWBPills(); renderWBGrid(); }

function renderWBGrid() {
  const f = wbCat === 'all' ? wbData : wbData.filter(w => w.cat === wbCat);
  document.getElementById('wbGrid').innerHTML = f.map(w => `
    <div class="wb-card">
      <div class="wb-card-img">
        <img src="${w.img}" alt="${w.title}" loading="lazy">
        <div class="wb-card-date">${w.date}</div>
      </div>
      <div class="wb-card-body">
        <span class="wb-card-cat">${w.cat}</span>
        <div class="wb-card-title">${w.title}</div>
        <div class="wb-card-excerpt">${w.excerpt}</div>
        <div class="wb-card-chips">${w.chips.map(c => `<span class="wb-chip">${c}</span>`).join('')}</div>
      </div>
      <div class="wb-card-footer">
        <div class="wb-card-chips">${w.chips.slice(0,2).map(c => `<span class="wb-chip" style="background:rgba(212,64,64,.1);color:var(--red);border-color:rgba(212,64,64,.2)">${c}</span>`).join('')}</div>
        <span class="wb-card-more">Read More →</span>
      </div>
    </div>`).join('');
}

/* ══ GAMES ══════════════════════════════ */
function renderGames() {
  document.getElementById('gContent').innerHTML = gamesData.map(g => `
    <div class="game-card">
      <div class="game-cover">
        <img src="${g.img}" alt="${g.title}">
        <div class="game-cover-over">
          <div class="gco-st">${g.status} — ${g.engine}</div>
          <div class="gco-t">${g.title}</div>
        </div>
      </div>
      <div class="game-body">
        <div>
          <p class="gb-desc">${g.desc}</p>
          <div class="gb-tags">${g.tags.map(t => `<span class="gb-tag">${t}</span>`).join('')}</div>
        </div>
        <div class="g-aside">
          <div class="ga-lbl">Features</div>
          ${g.feats.map(f => `<div class="ga-feat">${f}</div>`).join('')}
          <div class="ga-tgt"><strong>Target</strong><span>${g.target}</span></div>
        </div>
      </div>
    </div>`).join('');
}

/* ══ GALLERY MODAL ══════════════════════ */
let gmSrc = '', gmIdx = 0, gmData = [];

function openGM(src, idx) {
  gmSrc = src;
  gmData = src === 'port' ? currentPortFiltered : currentSkFiltered;
  gmIdx = idx;
  showGM();
  document.getElementById('gModal').classList.add('open');
}

function showGM() {
  const d = gmData[gmIdx];
  if (!d) return;
  const imgSrc = d.img || '';
  document.getElementById('gm-img').src = imgSrc || 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="400" height="400"><rect fill="%23151010"/><text fill="%23555" x="50%" y="50%" font-size="18" text-anchor="middle" dy=".35em">No Image</text></svg>';

  if (gmSrc === 'port') {
    document.getElementById('gm-cat').textContent = d.cat;
    document.getElementById('gm-title').textContent = d.title;
    document.getElementById('gm-meta').innerHTML = `
      <div class="gm-row"><span class="gm-lbl">Year</span><span class="gm-val">${d.year}</span></div>
      <div class="gm-row"><span class="gm-lbl">Medium</span><span class="gm-val">${d.medium}</span></div>
      <div class="gm-row"><span class="gm-lbl">Software</span><span class="gm-val">${d.software}</span></div>`;
    document.getElementById('gm-desc').textContent = d.desc;
    document.getElementById('gm-tags').innerHTML = d.tags.map(t => `<span class="gm-tag">${t}</span>`).join('');
    document.getElementById('gm-link-in').value = d.link || '';
  } else {
    document.getElementById('gm-cat').textContent = 'Sketch';
    document.getElementById('gm-title').textContent = d.lbl;
    document.getElementById('gm-meta').innerHTML = `
      <div class="gm-row"><span class="gm-lbl">Year</span><span class="gm-val">${d.year}</span></div>`;
    document.getElementById('gm-desc').textContent = d.desc || '';
    document.getElementById('gm-tags').innerHTML = '';
    document.getElementById('gm-link-in').value = '';
  }
}

function gmPrev() { if (gmIdx > 0) { gmIdx--; showGM(); } }
function gmNext() { if (gmIdx < gmData.length - 1) { gmIdx++; showGM(); } }
function closeGM() { document.getElementById('gModal').classList.remove('open'); }
function openGMLink() { const v = document.getElementById('gm-link-in').value; if (v) window.open(v, '_blank'); }
document.getElementById('gModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeGM(); });
document.addEventListener('keydown', e => {
  if (!document.getElementById('gModal').classList.contains('open')) return;
  if (e.key === 'Escape') closeGM();
  if (e.key === 'ArrowLeft') gmPrev();
  if (e.key === 'ArrowRight') gmNext();
});


/* INIT */
renderServices();
renderArchive();
renderPort();
renderSk();
renderWBPills();
renderWBGrid();
renderGames();
</script>
</body>
</html>
